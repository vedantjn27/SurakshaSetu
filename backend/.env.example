# ─────────────────────────────────────────────
#  SurakshaSetu — Environment Variables Template
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB Atlas
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=suraksha_setu

# Mistral AI (https://console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# JWT Authentication
JWT_SECRET_KEY=change_this_to_a_random_32_character_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# PII Scrambler (deterministic seed — keep secret, never change after data is scrambled)
SCRAMBLER_SECRET_SEED=change_this_to_a_random_secret_seed

# App Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
